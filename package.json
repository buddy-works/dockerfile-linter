{
    "name": "dockerlinter",
    "version": "1.2.2",
    "description": "Dockerfile linter",
    "keywords": [
        "docker",
        "dockerfile",
        "lint",
        "linter"
    ],
    "license": "GPL-3.0-or-later",
    "author": "Buddy",
    "repository": {
        "type": "git",
        "url": "https://github.com/buddy-works/dockerfile-linter.git"
    },
    "bin": "./bin/dockerfilelinter.js",
    "type": "module",
    "main": "./bin/dockerfilelinter.js",
    "scripts": {
        "test": "vitest run",
        "lint": "node ./bin/dockerfilelinter.js",
        "oxlint": "oxlint",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "version": "echo $npm_package_version",
        "postinstall": "node ./scripts/fetch-shellcheck.js"
    },
    "dependencies": {
        "chalk": "5.6.2",
        "commander": "15.0.0",
        "js-yaml": "5.2.1"
    },
    "devDependencies": {
        "oxfmt": "0.58.0",
        "oxlint": "1.73.0",
        "vitest": "4.1.10"
    },
    "engines": {
        "node": ">=22.12.0"
    }
}
