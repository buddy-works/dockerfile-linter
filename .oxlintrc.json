{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["unicorn", "node", "import", "promise", "oxc"],
    "env": { "builtin": true, "node": true },
    "categories": {
        "correctness": "error",
        "suspicious": "warn",
        "perf": "warn"
    },
    "overrides": [
        {
            "files": ["test/**/*.test.js"],
            "rules": {
                "no-unused-expressions": "off"
            }
        }
    ]
}
